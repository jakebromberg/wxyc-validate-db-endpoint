{
  "name": "wxyc-validate-db-endpoint",
  "version": "1.0.0",
  "description": "Validates that the library DB is up and search is working",
  "main": "dist/wxyc-validate-db-endpoint.js",
  "scripts": {
    "start": "node dist/wxyc-validate-db-endpoint.js",
    "dev": "ts-node wxyc-validate-db-endpoint.ts",
    "dev:watch": "nodemon --exec ts-node wxyc-validate-db-endpoint.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "axios": "^0.27.2",
    "dotenv": "^16.0.3",
    "express": "^4.18.1",
    "node-ssh": "^13.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.14",
    "@types/node-ssh": "^7.0.6",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "*.ts",
      "!*.d.ts",
      "!dist/**",
      "!node_modules/**"
    ],
    "modulePathIgnorePatterns": [
      "dist/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(.*\\.mjs$))"
    ]
  }
}
